{
    // User Interface
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": true,
    "explorer.autoReveal": "focusNoScroll",
    "editor.minimap.enabled": false,
    "editor.stickyScroll.enabled": true,
    "editor.fontLigatures": true,
    "workbench.editor.empty.hint": "hidden",
    "workbench.editorLargeFileConfirmation": 100,
    "workbench.tree.indent": 20,
    "remote.autoForwardPortsSource": "hybrid",
    "editor.rulers": [
        80,
        88,
        100
    ],
    // Appearance
    "window.zoomPerWindow": false,
    "editor.fontFamily": "'Fira Code', 'JetBrainsMono Nerd Font', Menlo, Monaco, 'Courier New', monospace",
    "window.autoDetectColorScheme": true,
    "workbench.colorTheme": "Default Light Modern",
    "workbench.preferredLightColorTheme": "Default Light+",
    "workbench.preferredDarkColorTheme": "GitHub Dark Default",
    "workbench.sideBar.location": "right",
    "editor.fontSize": 12,
    "window.zoomLevel": -0.7,
    // indentRainbow
    "indentRainbow.colors": [
        "rgba(255,127,255,0.05)",
        "rgba(250, 250, 0, 0.05)",
        "rgba(127,255,127,0.05)",
        "rgba(79,236,236,0.05)"
    ],
    // Python User-level Fallback
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true
    },
    // TOML User-level Fallback
    "[toml]": {
        "editor.defaultFormatter": "tamasfe.even-better-toml",
        "editor.formatOnSave": true
    },
    "evenBetterToml.formatter.indentEntries": true,
    "evenBetterToml.formatter.indentString": "    ",
    "evenBetterToml.formatter.alignEntries": true,
    "evenBetterToml.formatter.alignComments": true,
    // YAML User-level Fallback
    "[yaml]": {
        "editor.formatOnSave": true,
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "keep",
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultColorDecorators": "never",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        }
    },
    // Git
    // "git.autofetch": true,
    "git.openRepositoryInParentFolders": "never"
}