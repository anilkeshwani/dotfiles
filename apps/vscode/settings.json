{
    // User Interface
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": true,
    "explorer.autoReveal": "focusNoScroll",
    "editor.minimap.enabled": false,
    "editor.stickyScroll.enabled": true,
    "editor.fontLigatures": true,
    "workbench.editor.empty.hint": "hidden",
    "workbench.editorLargeFileConfirmation": 100,
    "workbench.tree.indent": 20,
    "remote.autoForwardPortsSource": "hybrid",
    "editor.rulers": [
        80,
        88,
        100
    ],
    "window.zoomPerWindow": false,
    "editor.inlineSuggest.enabled": true,
    "window.confirmBeforeClose": "keyboardOnly",
    // Appearance
    "editor.fontFamily": "'Fira Code', 'JetBrainsMono Nerd Font', Menlo, Monaco, 'Courier New', monospace",
    "window.autoDetectColorScheme": true,
    "workbench.colorTheme": "Default Light Modern",
    "workbench.iconTheme": "catppuccin-mocha",
    "workbench.sideBar.location": "right",
    "editor.fontSize": 12,
    // indentRainbow (indent-rainbow by oderwat)
    "indentRainbow.colors": [
        "rgba(255,127,255,0.05)",
        "rgba(250, 250, 0, 0.05)",
        "rgba(127,255,127,0.05)",
        "rgba(79,236,236,0.05)"
    ],
    // Python User-level Fallback
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "always",
            "source.organizeImports.ruff": "always"
        }
    },
    // ty Python LSP
    "python.languageServer": "None",
    // Disable Pylance/pylint since ty owns diagnostics
    "python.analysis.ignore": [
        "*"
    ],
    "pylint.enabled": false,
    // ty settings
    "ty.importStrategy": "fromEnvironment", // use uv venv, not bundled ty
    // TOML User-level Fallback
    "[toml]": {
        "editor.defaultFormatter": "tamasfe.even-better-toml",
        "editor.formatOnSave": true
    },
    "evenBetterToml.formatter.indentEntries": true,
    "evenBetterToml.formatter.indentString": "    ",
    "evenBetterToml.formatter.alignEntries": true,
    "evenBetterToml.formatter.alignComments": true,
    // YAML User-level Fallback
    "[yaml]": {
        "editor.formatOnSave": true,
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "keep",
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultColorDecorators": "never",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        }
    },
    // Git
    // "git.autofetch": true,
    "git.openRepositoryInParentFolders": "never",
    // Chat (GitHub Copilot Chat)
    "chat.checkpoints.showFileChanges": true,
    "chat.planAgent.defaultModel": "GPT-5.3-Codex (copilot)",
    "chat.tools.terminal.preventShellHistory": false,
    "claudeCode.useTerminal": true,
    "redhat.telemetry.enabled": false,
    "window.zoomLevel": -1,
    "workbench.preferredDarkColorTheme": "Visual Studio Dark",
    "workbench.preferredLightColorTheme": "Default Light+"
}