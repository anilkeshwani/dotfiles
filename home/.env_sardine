# ~/.env_sardine — Sardine HPC server env, sourced on artemis/poseidon/dionysus/hades.

# User-local binaries — prefer ~/.local/bin (user-installed), then ~/bin (Sardine system)
export PATH="${HOME}/.local/bin:$PATH:${HOME}/bin"

# Scratch storage home (server-specific; artemis path used as canonical)
export HAFH='/mnt/scratch-artemis/anilkeshwani'

# Load jq from module system
module load jq

# Fall back to xterm-256color if the current TERM has no terminfo entry (e.g. xterm-ghostty)
if ! infocmp "$TERM" &>/dev/null 2>&1; then
    export TERM=xterm-256color
fi
