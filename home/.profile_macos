# ~/.profile_macos — macOS login-shell extras, sourced from ~/.profile on Darwin.

# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

# Silence bash deprecation warning (macOS ships bash 3.x as default)
export BASH_SILENCE_DEPRECATION_WARNING=1

# Global project paths
export GARDEN="${HOME}/Desktop/garden-builder"
export JOURNAL="${HOME}/Desktop/journal"

# Cargo (Rust)
[ -f "${HOME}/.cargo/env" ] && . "${HOME}/.cargo/env"

# Ruby — chruby
. /opt/homebrew/opt/chruby/share/chruby/chruby.sh
. /opt/homebrew/opt/chruby/share/chruby/auto.sh
chruby ruby-3.1.3

# Volta
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"
