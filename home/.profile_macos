# ~/.profile_macos — macOS login-shell extras, sourced from ~/.profile on Darwin.

# Homebrew (guarded: Intel Macs install under /usr/local, not /opt/homebrew).
# An interactive bash login sources .bashrc first, so .env_macos may already
# have initialized Homebrew by the time this profile is reached.
if [ -x /opt/homebrew/bin/brew ] && [ -z "${HOMEBREW_PREFIX:-}" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Silence bash deprecation warning (macOS ships bash 3.x as default)
export BASH_SILENCE_DEPRECATION_WARNING=1

# Global project paths
export GARDEN="${HOME}/Desktop/garden-builder"
export JOURNAL="${HOME}/Desktop/journal"

# Cargo (Rust)
[ -f "${HOME}/.cargo/env" ] && . "${HOME}/.cargo/env"

# Ruby — chruby (guarded: not every Mac has it installed)
if [ -f /opt/homebrew/opt/chruby/share/chruby/chruby.sh ]; then
    . /opt/homebrew/opt/chruby/share/chruby/chruby.sh
    . /opt/homebrew/opt/chruby/share/chruby/auto.sh
    chruby ruby-3.1.3
fi
