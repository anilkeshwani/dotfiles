# ~/.env_linux — Linux-specific env, sourced from .bashrc/.zshrc on Linux.

# Homebrew — ensure /home/linuxbrew/.linuxbrew/bin is on PATH for non-login shells.
# HOMEBREW_PREFIX is exported by shellenv, so skip when a login shell already ran it
# (.profile_linux) — rerunning duplicates the PATH entries.
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ] && [ -z "${HOMEBREW_PREFIX:-}" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
