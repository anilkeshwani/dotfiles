# ~/.env_macos — macOS-specific env, sourced from .bashrc/.zshrc on Darwin.

# Homebrew — ensure /opt/homebrew/bin is on PATH for non-login shells.
# HOMEBREW_PREFIX is exported by shellenv, so skip when a login shell already ran it
# (.profile_macos) — rerunning duplicates the PATH entries.
if [ -x /opt/homebrew/bin/brew ] && [ -z "${HOMEBREW_PREFIX:-}" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Antigravity
export PATH="${HOME}/.antigravity/antigravity/bin:$PATH"

# NVM: pin to lts/iron (v20) — used by quartz
if command -v nvm >/dev/null 2>&1; then
    nvm use --silent lts/iron >/dev/null 2>&1 || true
fi
