# ~/.prompt — shared prompt helpers, sourced by both .bashrc and .zshrc.

# Helper: emit current git branch with leading icon, or nothing if not in a repo.
_prompt_git_branch() {
    local branch
    branch=$(git branch --show-current 2>/dev/null) || return
    [ -n "$branch" ] && printf '  %s' "$branch"  # raw U+E0A0 Powerline branch icon; not $'\ue0a0', which aborts under C/POSIX locales
}

# Helper: emit active virtualenv name in parens, or nothing.
_prompt_venv() {
    [ -n "$VIRTUAL_ENV" ] && printf ' (%s)' "$(basename "$VIRTUAL_ENV")"
}
