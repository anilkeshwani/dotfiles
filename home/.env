# ~/.env — shell-agnostic exported env vars and PATH additions.
# Sourced by both .bashrc and .zshrc.

# Login shells reach this file twice (.zprofile + .zshrc; .profile + .bashrc) — bail on
# the second pass. Deliberately not exported: nested shells must re-source to get nvm's
# shell functions, which don't survive exec.
[ -n "${_DOTFILES_ENV_SOURCED:-}" ] && return 0
_DOTFILES_ENV_SOURCED=1

# Add to PATH only if absent — nested shells inherit PATH, so unconditional edits duplicate
_path_has() { case ":${PATH}:" in *":$1:"*) return 0 ;; *) return 1 ;; esac; }

# User-local binaries
_path_has "${HOME}/.local/bin" || export PATH="$PATH:${HOME}/.local/bin"

# NVM — Node Version Manager
# Sourced here for PATH; machine-specific version pins are in .env_macos / .env_linux
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"

# Volta — alternative Node version manager (kept alongside NVM for compatibility)
export VOLTA_HOME="$HOME/.volta"
_path_has "$VOLTA_HOME/bin" || export PATH="$VOLTA_HOME/bin:$PATH"

# Go: add compiled binaries to PATH
if command -v go >/dev/null 2>&1; then
    _gobin="$(go env GOPATH)/bin"
    _path_has "$_gobin" || export PATH="$PATH:$_gobin"
    unset _gobin
fi

unset -f _path_has

# Dagster — root dir for instance config, logs, and local run storage
export DAGSTER_HOME="$HOME/.dagster_home"

# Terminfo for uv-installed Python tools (nvitop, etc.).
# uv ships python-build-standalone, whose bundled ncurses ignores Debian/Ubuntu's
# terminfo locations — so curses TUIs fail with "could not find terminfo database".
if [ "$(uname -s)" = "Linux" ] && [ -z "${TERMINFO_DIRS:-}" ]; then
    export TERMINFO_DIRS="/etc/terminfo:/lib/terminfo:/usr/share/terminfo"
fi
